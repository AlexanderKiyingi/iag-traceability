SERVICE_NAME=traceability
PORT=4011
LOG_LEVEL=info
ENVIRONMENT=development

AUTH_MODE=jwt
JWT_ISSUER=http://localhost:3001
JWKS_URL=http://localhost:3001/.well-known/jwks.json
AUDIENCE=iag.traceability
SERVICE_CLIENT_ID=iag-traceability
SERVICE_CLIENT_SECRET=
AUTH_TOKEN_URL=http://localhost:3001/oauth/token

GATEWAY_API_PREFIX=/api/v1/traceability
PUBLIC_TRACE_BASE_URL=http://localhost:8080/api/v1/traceability/public/q
PUBLIC_API_URL=http://localhost:8080

DATABASE_URL=postgres://svc_iag_traceability:iag_traceability_dev@localhost:5432/iag_platform?sslmode=disable
REDIS_URL=redis://127.0.0.1:6379/0
AUTO_MIGRATE=true

KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=iag.traceability
KAFKA_SUPPLY_CHAIN_TOPIC=iag.supply-chain
KAFKA_PRODUCTION_TOPIC=iag.production
KAFKA_QUALITY_TOPIC=iag.quality

SUPPLY_CHAIN_BASE_URL=http://127.0.0.1:4007
SUPPLY_CHAIN_AUDIENCE=iag.supply-chain

# Public-surface hardening
PUBLIC_RATE_LIMIT=60
PUBLIC_RATE_BURST=10
# Proxy IPs/CIDRs allowed to set X-Forwarded-For for client-IP rate limiting.
# Empty = trust none (limiter cannot be spoofed). Set to the gateway in prod.
TRUSTED_PROXIES=
# Expose precise farm/farmer GPS in the public QR payload (default false coarsens ~1km).
PUBLIC_PRECISE_GEO=false
