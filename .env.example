# Local dev — see config/.env.example for full reference.
SERVICE_NAME=traceability
PORT=4011
AUTH_MODE=jwt
DATABASE_URL=postgres://svc_iag_traceability:iag_traceability_dev@localhost:5432/iag_platform?sslmode=disable
REDIS_URL=redis://127.0.0.1:6379/0
CACHE_TTL=5m
AUTO_MIGRATE=true
PUBLIC_RATE_LIMIT=60
PUBLIC_RATE_BURST=10
STORY_PLACEHOLDER_JOURNEY=false
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
# Comma-separated proxy IPs/CIDRs allowed to set X-Forwarded-For. Empty = trust
# none (rate limiter cannot be spoofed). In prod set to the gateway address(es).
TRUSTED_PROXIES=
# Expose precise farm/farmer GPS in the public QR payload. Default false coarsens
# coordinates to ~1km to protect smallholder location privacy.
PUBLIC_PRECISE_GEO=false
